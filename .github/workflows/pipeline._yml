#Note: Tentative avec les Actions mais non concluant.
#Ne se déclanche pas suivant la cédule du tout 
#Travaille 10% du temps...


name: Pipeline Supabase Test

on:
  workflow_dispatch:
  schedule:
    - cron: "7 * * * *"
    - cron: "18 * * * *"

jobs:
  run-pipeline:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout du code
        uses: actions/checkout@v4

      - name: Installer Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - name: Installer les dépendances
        run: pip install -r requirements.txt

      - name: Exécuter le script
        env:
          DATABASE_URL: ${{ secrets.DATABASE_URL }}
        run: python main.py


